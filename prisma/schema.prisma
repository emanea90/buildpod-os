// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model organizations {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  memberships      organization_memberships[]
  assets           assets[]
  jobs             jobs[]
  events           events[]
  maintenance      maintenance_events[]
  locations        locations[]
  staging_sessions staging_sessions[]
}

model users {
  id         String   @id
  email      String
  created_at DateTime @default(now())

  memberships              organization_memberships[]
  started_staging_sessions staging_sessions[]
}

model organization_memberships {
  id              String          @id @default(uuid())
  organization_id String
  user_id         String
  role            membership_role
  created_at      DateTime        @default(now())

  organization organizations @relation(fields: [organization_id], references: [id])
  user         users         @relation(fields: [user_id], references: [id])

  @@unique([organization_id, user_id])
}

enum membership_role {
  owner
  admin
  manager
  technician
  viewer
}

model assets {
  id              String       @id @default(uuid())
  organization_id String
  name            String
  asset_type      String
  status          asset_status
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  organization     organizations        @relation(fields: [organization_id], references: [id])
  assignments      job_assignments[]
  maintenance      maintenance_events[]
  staging_sessions staging_sessions[]
}

enum asset_status {
  available
  staged
  deployed
  maintenance
  offline
}

model jobs {
  id              String     @id @default(uuid())
  organization_id String
  title           String
  description     String?
  status          job_status
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  organization     organizations      @relation(fields: [organization_id], references: [id])
  assignments      job_assignments[]
  staging_sessions staging_sessions[]
}

enum job_status {
  draft
  planned
  staging
  ready
  in_progress
  blocked
  completed
  archived
}

model job_assignments {
  id       String @id @default(uuid())
  job_id   String
  asset_id String

  job   jobs   @relation(fields: [job_id], references: [id])
  asset assets @relation(fields: [asset_id], references: [id])

  @@unique([job_id, asset_id])
}

model maintenance_events {
  id              String             @id @default(uuid())
  organization_id String
  asset_id        String
  description     String
  status          maintenance_status
  created_at      DateTime           @default(now())

  organization organizations @relation(fields: [organization_id], references: [id])
  asset        assets        @relation(fields: [asset_id], references: [id])
}

enum maintenance_status {
  open
  scheduled
  in_progress
  completed
}

model events {
  id              String   @id @default(uuid())
  organization_id String
  entity_type     String
  entity_id       String
  event_type      String
  payload_json    Json?
  user_id         String?
  created_at      DateTime @default(now())

  organization organizations @relation(fields: [organization_id], references: [id])
}

enum location_type {
  warehouse
  shop
  jobsite
  trailer_bay
  hangar
  yard
  other
}

model locations {
  id                 String        @id @default(uuid())
  organization_id    String
  name               String
  location_type      location_type
  parent_location_id String?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  organization organizations @relation(fields: [organization_id], references: [id])
  parent       locations?    @relation("location_hierarchy", fields: [parent_location_id], references: [id])
  children     locations[]   @relation("location_hierarchy")

  @@index([organization_id])
  @@index([parent_location_id])
}

enum staging_status {
  draft
  in_progress
  verified
  failed
  completed
}

enum staging_item_type {
  asset
  inventory
  checklist
}

enum verification_status {
  pending
  verified
  missing
  issue
}

model staging_sessions {
  id                 String         @id @default(uuid())
  organization_id    String
  target_asset_id    String
  target_job_id      String?
  started_by_user_id String?
  status             staging_status @default(draft)
  notes              String?
  started_at         DateTime       @default(now())
  completed_at       DateTime?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  organization organizations           @relation(fields: [organization_id], references: [id])
  target_asset assets                  @relation(fields: [target_asset_id], references: [id])
  target_job   jobs?                   @relation(fields: [target_job_id], references: [id])
  started_by   users?                  @relation(fields: [started_by_user_id], references: [id])
  items        staging_session_items[]

  @@index([organization_id])
  @@index([target_asset_id])
  @@index([target_job_id])
  @@index([started_by_user_id])
  @@index([status])
}

model staging_session_items {
  id                  String              @id @default(uuid())
  staging_session_id  String
  item_type           staging_item_type
  referenced_item_id  String
  expected_quantity   Int?
  actual_quantity     Int?
  verification_status verification_status @default(pending)
  note                String?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  staging_session staging_sessions @relation(fields: [staging_session_id], references: [id])

  @@index([staging_session_id])
  @@index([item_type])
  @@index([referenced_item_id])
  @@index([verification_status])
}
